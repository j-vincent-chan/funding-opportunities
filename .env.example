# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only: cron matching route, local admin scripts (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: OpenAI for Community Snapshot narrative (server-only)
# OPENAI_API_KEY=sk-...

# Optional: contact email for NCBI E-utilities (PubMed stats on PI pages; politeness)
# NCBI_CONTACT_EMAIL=you@institution.edu

# Simpler.Grants.gov (NIH funding sync + cron pipeline; server-only)
# SIMPLER_GRANTS_API_KEY=...
# Optional: SIMPLER_GRANTS_API_BASE_URL=https://api.simpler.grants.gov

# Vercel Cron + manual cron routes (GET/POST /api/cron/*; uses SUPABASE_SERVICE_ROLE_KEY above)
# CRON_SECRET=...   # long random string; set in Vercel Production env for nightly sync

# Saved-search email digests (POST /api/cron/funding-search-notifications with same CRON_SECRET)
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL="Pursuit Queue <onboarding@resend.dev>"
# Public site URL for links in emails (optional; falls back to VERCEL_URL in production)
# NEXT_PUBLIC_SITE_URL=https://your-app.example.com
